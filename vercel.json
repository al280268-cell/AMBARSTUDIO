{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/uploads/(.*)", "dest": "api/index.py" },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map|webp))",
      "dest": "frontend/$1"
    },
    { "src": "/(.*)", "dest": "frontend/index.html" }
  ],
  "env": {
    "AMBAR_ENV": "production",
    "APP_MODE": "production",
    "FERNET_KEY": "nPGSCdgZxW8swuNllBwas2XNMv1rdngPlOKsL80OBI8=",
    "SECRET_KEY": "AmbarStudio2024-ProductionKey-XYZ-Aguascalientes"
  }
}
